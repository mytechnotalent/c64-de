{
    "version": "2.0.0",
    "inputs": [],
    "tasks": [
        {
            "label": "Set Active Project",
            "type": "shell",
            "command": "python3",
            "windows": {
                "command": "python"
            },
            "args": [
                "${workspaceFolder}/tools/set_active_project.py",
                "${workspaceFolder}",
                "${relativeFile}"
            ],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Format ASM",
            "type": "shell",
            "command": "python3",
            "windows": {
                "command": "python"
            },
            "args": [
                "${workspaceFolder}/tools/format_asm.py",
                "${file}"
            ],
            "group": "none",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build C64 Project",
            "type": "shell",
            "command": "bash",
            "windows": {
                "command": "${fileDirname}\\build.bat",
                "args": []
            },
            "args": [
                "${fileDirname}/build.sh"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build & Run C64 Project",
            "type": "shell",
            "command": "bash",
            "windows": {
                "command": "${fileDirname}\\build.bat",
                "args": [
                    "run"
                ]
            },
            "args": [
                "${fileDirname}/build.sh",
                "run"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build & Debug C64 Project",
            "type": "shell",
            "command": "bash",
            "windows": {
                "command": "${fileDirname}\\build.bat",
                "args": [
                    "debug"
                ]
            },
            "args": [
                "${fileDirname}/build.sh",
                "debug"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build for VS64 Debug",
            "type": "shell",
            "command": "java",
            "args": [
                "-jar",
                "${workspaceFolder}/KickAssembler/KickAss.jar",
                "${file}",
                "-debugdump",
                "-showmem",
                "-symbolfile",
                "-odir",
                "${fileDirname}/make",
                "-o",
                "${fileDirname}/make/${fileBasenameNoExtension}.prg"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}